{
    "manifest_version": 3,
    "name": "Moodle Forum Grader",
    "version": "1.0.0",
    "description": "Automatically grade Moodle forum discussions with AI analysis, plagiarism detection, and peer reply tracking.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "downloads"
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*/*",
                "http://*/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "overlay.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "overlay.css"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}